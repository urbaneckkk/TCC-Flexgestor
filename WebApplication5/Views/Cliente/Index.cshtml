<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Clientes - FlexGestor</title>
    <link rel="stylesheet" href="/css/homeCSS/home.css">
    <link rel="stylesheet" href="/css/menuCSS/menu.css">
    <link rel="stylesheet" href="/css/clienteCSS/cliente.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>
<body>
    <div class="container">
        <div id="menu"></div>

        <main>
            <section class="secao-clientes">

                <div class="cabecalho-tela">
                    <h2>Gerenciamento de Clientes</h2>
                    <button class="btn-novo-cliente" id="btn-abrir-modal">
                        <i class="bi bi-person-plus-fill"></i> Novo Cliente
                    </button>
                </div>

                <div class="table-container">
                    <div class="area-filtro">
                        <select id="select-tipo-filtro" class="select-filtro">
                            <option value="nome">Nome</option>
                            <option value="documento">CPF / CNPJ</option>
                        </select>
                        <input type="text" id="input-termo-busca" class="input-filtro" placeholder="Filtrar...">
                        <div class="filtro-status">
                            <button id="btn-filtro-todos" class="btn-status-filtro" onclick="setFiltroStatus('todos')">Todos</button>
                            <button id="btn-filtro-ativo" class="btn-status-filtro" onclick="setFiltroStatus('ativo')">Ativos</button>
                            <button id="btn-filtro-inativo" class="btn-status-filtro" onclick="setFiltroStatus('inativo')">Inativos</button>
                        </div>
                    </div>

                    <table class="table-clientes" id="tabela-clientes">
                        <thead>
                            <tr>
                                <th>Ações</th>
                                <th>Status</th>
                                <th>Tipo</th>
                                <th>Nome</th>
                                <th>CPF / CNPJ</th>
                                <th>Email</th>
                                <th>Telefone</th>
                                <th>Saldo Dev.</th>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>

                    <div class="paginacao">
                        <span class="paginacao-info"></span>
                        <div class="paginacao-controles"></div>
                    </div>
                </div>

            </section>
        </main>
    </div>

    <!-- ════════════════════════════════════════
         MODAL: NOVO CLIENTE
    ════════════════════════════════════════ -->
    <div class="modal" id="modal-novo-cliente" role="dialog" aria-modal="true" aria-labelledby="titulo-modal-novo">
        <div class="modal-content modal-large">
            <div class="modal-header">
                <h3 id="titulo-modal-novo"><i class="bi bi-person-plus-fill"></i> Novo Cliente</h3>
                <button class="btn-fechar-modal" id="btn-fechar-novo" aria-label="Fechar modal">&times;</button>
            </div>
            <div class="modal-body">
                <form id="form-cliente" novalidate>

                    <!-- Toggle PF / PJ -->
                    <div class="tipo-selector">
                        <span class="tipo-selector-label">Tipo de pessoa:</span>
                        <button type="button" class="tipo-btn tipo-btn-ativo" data-prefixo="novo" data-tipo="PF">
                            <i class="bi bi-person-fill"></i> Pessoa Física
                        </button>
                        <button type="button" class="tipo-btn" data-prefixo="novo" data-tipo="PJ">
                            <i class="bi bi-building"></i> Pessoa Jurídica
                        </button>
                    </div>

                    <!-- Identificação -->
                    <p class="form-secao">Identificação</p>
                    <div class="form-grid">
                        <div class="form-group form-col-2">
                            <label id="novo-label-nome" for="novo-nome">Nome Completo <span class="obrigatorio">*</span></label>
                            <input type="text" id="novo-nome" name="nome"
                                   placeholder="Nome do cliente" required maxlength="120" autocomplete="name">
                        </div>
                        <div class="form-group">
                            <label id="novo-label-doc" for="novo-doc">CPF <span class="obrigatorio">*</span></label>
                            <input type="text" id="novo-doc" name="cnpjCpf"
                                   placeholder="000.000.000-00" required maxlength="18"
                                   inputmode="numeric" autocomplete="off">
                        </div>

                        <!-- Campos exclusivos PF -->
                        <div class="form-group" id="novo-grupo-genero">
                            <label for="novo-genero">Gênero</label>
                            <select id="novo-genero" name="genero">
                                <option value="">Selecione</option>
                                <option value="M">Masculino</option>
                                <option value="F">Feminino</option>
                                <option value="O">Outro</option>
                            </select>
                        </div>
                        <div class="form-group" id="novo-grupo-nascimento">
                            <label for="novo-nascimento">Data de Nascimento</label>
                            <input type="date" id="novo-nascimento" name="dthNascimento">
                        </div>
                        <div class="form-group" id="novo-grupo-estadocivil">
                            <label for="novo-estadocivil">Estado Civil</label>
                            <select id="novo-estadocivil" name="estadoCivil">
                                <option value="">Selecione</option>
                                <option value="Solteiro">Solteiro(a)</option>
                                <option value="Casado">Casado(a)</option>
                                <option value="Divorciado">Divorciado(a)</option>
                                <option value="Viúvo">Viúvo(a)</option>
                            </select>
                        </div>

                        <!-- Campos exclusivos PJ -->
                        <div class="form-group form-col-2" id="novo-grupo-razaosocial" style="display:none">
                            <label for="novo-razaosocial">Razão Social <span class="obrigatorio">*</span></label>
                            <input type="text" id="novo-razaosocial" name="razaoSocial"
                                   placeholder="Razão social da empresa" maxlength="120">
                        </div>
                    </div>

                    <!-- Contato -->
                    <p class="form-secao">Contato</p>
                    <div class="form-grid">
                        <div class="form-group form-col-2">
                            <label for="novo-email">Email <span class="obrigatorio">*</span></label>
                            <input type="email" id="novo-email" name="email"
                                   placeholder="email@exemplo.com" required maxlength="80" autocomplete="email">
                        </div>
                        <div class="form-group">
                            <label for="novo-telefone">Telefone <span class="obrigatorio">*</span></label>
                            <input type="text" id="novo-telefone" name="telefone"
                                   placeholder="(00) 00000-0000" required maxlength="20"
                                   inputmode="tel" autocomplete="tel">
                        </div>
                    </div>

                    <!-- Endereço -->
                    <p class="form-secao">Endereço</p>
                    <div class="form-grid">
                        <div class="form-group form-col-2">
                            <label for="novo-logradouro">Logradouro <span class="obrigatorio">*</span></label>
                            <input type="text" id="novo-logradouro" placeholder="Rua, Av., etc." required maxlength="120">
                        </div>
                        <div class="form-group">
                            <label for="novo-numero">Número <span class="obrigatorio">*</span></label>
                            <input type="text" id="novo-numero" placeholder="ex: 123" required maxlength="20">
                        </div>
                        <div class="form-group">
                            <label for="novo-complemento">Complemento</label>
                            <input type="text" id="novo-complemento" placeholder="Apto, Sala, etc." maxlength="60">
                        </div>
                        <div class="form-group">
                            <label for="novo-bairro">Bairro</label>
                            <input type="text" id="novo-bairro" placeholder="Bairro" maxlength="80">
                        </div>
                        <div class="form-group">
                            <label for="novo-cidade">Cidade <span class="obrigatorio">*</span></label>
                            <input type="text" id="novo-cidade" placeholder="Cidade" required maxlength="80">
                        </div>
                        <div class="form-group">
                            <label for="novo-estado">Estado <span class="obrigatorio">*</span></label>
                            <select id="novo-estado" required>
                                <option value="">Selecione</option>
                                <option>AC</option>
                                <option>AL</option>
                                <option>AP</option>
                                <option>AM</option>
                                <option>BA</option>
                                <option>CE</option>
                                <option>DF</option>
                                <option>ES</option>
                                <option>GO</option>
                                <option>MA</option>
                                <option>MT</option>
                                <option>MS</option>
                                <option>MG</option>
                                <option>PA</option>
                                <option>PB</option>
                                <option>PR</option>
                                <option>PE</option>
                                <option>PI</option>
                                <option>RJ</option>
                                <option>RN</option>
                                <option>RS</option>
                                <option>RO</option>
                                <option>RR</option>
                                <option>SC</option>
                                <option>SP</option>
                                <option>SE</option>
                                <option>TO</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label for="novo-cep">CEP</label>
                            <input type="text" id="novo-cep" placeholder="00000-000" maxlength="9" inputmode="numeric">
                        </div>
                    </div>

                    <!-- Dados Comerciais -->
                    <p class="form-secao">Dados Comerciais</p>
                    <div class="form-grid">
                        <div class="form-group">
                            <label for="novo-tipocliente">Tipo de Cliente</label>
                            <select id="novo-tipocliente" name="tipoClienteId">
                                <option value="1">Padrão</option>
                                <option value="2">VIP</option>
                                <option value="3">Atacado</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label for="novo-saldo">Saldo Devedor (R$)</label>
                            <input type="number" id="novo-saldo" name="saldoDevedor"
                                   placeholder="0,00" min="0" step="0.01">
                        </div>
                        <div class="form-group form-col-2">
                            <label for="novo-observacao">Observação</label>
                            <textarea id="novo-observacao" name="observacao"
                                      placeholder="Observações sobre o cliente..." maxlength="300"></textarea>
                        </div>
                    </div>

                    <div class="modal-footer">
                        <button type="button" class="btn-secundario" id="btn-cancelar-novo">Cancelar</button>
                        <button type="submit" class="btn-primario" id="btn-salvar-novo">
                            <i class="bi bi-check-lg"></i>
                            <span class="btn-texto">Salvar</span>
                            <span class="btn-loading" style="display:none">
                                <i class="bi bi-hourglass-split"></i> Salvando...
                            </span>
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- ════════════════════════════════════════
         MODAL: EDIÇÃO
    ════════════════════════════════════════ -->
    <div class="modal" id="modal-edicao" role="dialog" aria-modal="true" aria-labelledby="titulo-modal-edicao">
        <div class="modal-content modal-large">
            <div class="modal-header">
                <h3 id="titulo-modal-edicao"><i class="bi bi-pencil-fill"></i> Editar Cliente</h3>
                <button class="btn-fechar-modal" id="btn-fechar-edicao" aria-label="Fechar modal">&times;</button>
            </div>
            <div class="modal-body">
                <form id="form-edicao" novalidate>

                    <!-- Toggle PF / PJ -->
                    <div class="tipo-selector">
                        <span class="tipo-selector-label">Tipo de pessoa:</span>
                        <button type="button" class="tipo-btn tipo-btn-ativo" data-prefixo="edit" data-tipo="PF">
                            <i class="bi bi-person-fill"></i> Pessoa Física
                        </button>
                        <button type="button" class="tipo-btn" data-prefixo="edit" data-tipo="PJ">
                            <i class="bi bi-building"></i> Pessoa Jurídica
                        </button>
                    </div>

                    <!-- Identificação -->
                    <p class="form-secao">Identificação</p>
                    <div class="form-grid">
                        <div class="form-group form-col-2">
                            <label id="edit-label-nome" for="edit-nome">Nome Completo <span class="obrigatorio">*</span></label>
                            <input type="text" id="edit-nome" name="nome"
                                   required maxlength="120" autocomplete="name">
                        </div>
                        <div class="form-group">
                            <label id="edit-label-doc" for="edit-doc">CPF <span class="obrigatorio">*</span></label>
                            <input type="text" id="edit-doc" name="cnpjCpf"
                                   required maxlength="18" inputmode="numeric" autocomplete="off">
                        </div>

                        <!-- Campos exclusivos PF -->
                        <div class="form-group" id="edit-grupo-genero">
                            <label for="edit-genero">Gênero</label>
                            <select id="edit-genero" name="genero">
                                <option value="">Selecione</option>
                                <option value="M">Masculino</option>
                                <option value="F">Feminino</option>
                                <option value="O">Outro</option>
                            </select>
                        </div>
                        <div class="form-group" id="edit-grupo-nascimento">
                            <label for="edit-nascimento">Data de Nascimento</label>
                            <input type="date" id="edit-nascimento" name="dthNascimento">
                        </div>
                        <div class="form-group" id="edit-grupo-estadocivil">
                            <label for="edit-estadocivil">Estado Civil</label>
                            <select id="edit-estadocivil" name="estadoCivil">
                                <option value="">Selecione</option>
                                <option value="Solteiro">Solteiro(a)</option>
                                <option value="Casado">Casado(a)</option>
                                <option value="Divorciado">Divorciado(a)</option>
                                <option value="Viúvo">Viúvo(a)</option>
                            </select>
                        </div>

                        <!-- Campos exclusivos PJ -->
                        <div class="form-group form-col-2" id="edit-grupo-razaosocial" style="display:none">
                            <label for="edit-razaosocial">Razão Social <span class="obrigatorio">*</span></label>
                            <input type="text" id="edit-razaosocial" name="razaoSocial" maxlength="120">
                        </div>
                    </div>

                    <!-- Contato -->
                    <p class="form-secao">Contato</p>
                    <div class="form-grid">
                        <div class="form-group form-col-2">
                            <label for="edit-email">Email <span class="obrigatorio">*</span></label>
                            <input type="email" id="edit-email" name="email"
                                   required maxlength="80" autocomplete="email">
                        </div>
                        <div class="form-group">
                            <label for="edit-telefone">Telefone <span class="obrigatorio">*</span></label>
                            <input type="text" id="edit-telefone" name="telefone"
                                   required maxlength="20" inputmode="tel" autocomplete="tel">
                        </div>
                    </div>

                    <!-- Endereço -->
                    <p class="form-secao">Endereço</p>
                    <div class="form-grid">
                        <div class="form-group form-col-2">
                            <label for="edit-logradouro">Logradouro <span class="obrigatorio">*</span></label>
                            <input type="text" id="edit-logradouro" required maxlength="120">
                        </div>
                        <div class="form-group">
                            <label for="edit-numero">Número <span class="obrigatorio">*</span></label>
                            <input type="text" id="edit-numero" required maxlength="20">
                        </div>
                        <div class="form-group">
                            <label for="edit-complemento">Complemento</label>
                            <input type="text" id="edit-complemento" maxlength="60">
                        </div>
                        <div class="form-group">
                            <label for="edit-bairro">Bairro</label>
                            <input type="text" id="edit-bairro" maxlength="80">
                        </div>
                        <div class="form-group">
                            <label for="edit-cidade">Cidade <span class="obrigatorio">*</span></label>
                            <input type="text" id="edit-cidade" required maxlength="80">
                        </div>
                        <div class="form-group">
                            <label for="edit-estado">Estado <span class="obrigatorio">*</span></label>
                            <select id="edit-estado" required>
                                <option value="">Selecione</option>
                                <option>AC</option>
                                <option>AL</option>
                                <option>AP</option>
                                <option>AM</option>
                                <option>BA</option>
                                <option>CE</option>
                                <option>DF</option>
                                <option>ES</option>
                                <option>GO</option>
                                <option>MA</option>
                                <option>MT</option>
                                <option>MS</option>
                                <option>MG</option>
                                <option>PA</option>
                                <option>PB</option>
                                <option>PR</option>
                                <option>PE</option>
                                <option>PI</option>
                                <option>RJ</option>
                                <option>RN</option>
                                <option>RS</option>
                                <option>RO</option>
                                <option>RR</option>
                                <option>SC</option>
                                <option>SP</option>
                                <option>SE</option>
                                <option>TO</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label for="edit-cep">CEP</label>
                            <input type="text" id="edit-cep" maxlength="9" inputmode="numeric">
                        </div>
                    </div>

                    <!-- Dados Comerciais -->
                    <p class="form-secao">Dados Comerciais</p>
                    <div class="form-grid">
                        <div class="form-group">
                            <label for="edit-tipocliente">Tipo de Cliente</label>
                            <select id="edit-tipocliente" name="tipoClienteId">
                                <option value="1">Padrão</option>
                                <option value="2">VIP</option>
                                <option value="3">Atacado</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label for="edit-saldo">Saldo Devedor (R$)</label>
                            <input type="number" id="edit-saldo" name="saldoDevedor" min="0" step="0.01">
                        </div>
                        <div class="form-group">
                            <label for="edit-cadastro">Data de Cadastro</label>
                            <input type="text" id="edit-cadastro" name="dthCadastro" readonly>
                        </div>
                        <div class="form-group form-col-2">
                            <label for="edit-observacao">Observação</label>
                            <textarea id="edit-observacao" name="observacao" maxlength="300"></textarea>
                        </div>
                    </div>

                    <div class="modal-footer">
                        <button type="button" class="btn-secundario" id="btn-cancelar-edicao">Cancelar</button>
                        <button type="submit" class="btn-primario" id="btn-salvar-edicao">
                            <i class="bi bi-check-lg"></i>
                            <span class="btn-texto">Salvar Alterações</span>
                            <span class="btn-loading" style="display:none">
                                <i class="bi bi-hourglass-split"></i> Salvando...
                            </span>
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- ════════════════════════════════════════
         MODAL: CONFIRMAÇÃO
    ════════════════════════════════════════ -->
    <div class="modal" id="modal-confirmar" role="dialog" aria-modal="true" aria-labelledby="titulo-modal-confirmar">
        <div class="modal-content" style="width:420px">
            <div class="modal-header">
                <h3 id="titulo-modal-confirmar">
                    <i class="bi bi-exclamation-triangle-fill" style="color:#ef4444"></i> Confirmação
                </h3>
                <button class="btn-fechar-modal" id="btn-fechar-confirmar" aria-label="Fechar modal">&times;</button>
            </div>
            <div class="confirm-body">
                <div class="confirm-icone">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                </div>
                <p id="confirm-mensagem">Deseja inativar este cliente?</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn-secundario" id="btn-confirmar-nao">Não, cancelar</button>
                <button type="button" class="btn-perigo" id="confirm-btn-sim">Sim, inativar</button>
            </div>
        </div>
    </div>

    <script src="/js/menuJS/menu.js"></script>
    <script src="/js/clienteJS/cliente.js"></script>
</body>
</html>
