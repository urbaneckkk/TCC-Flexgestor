<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Estoque - FlexGestor</title>
    <link rel="stylesheet" href="/css/homeCSS/home.css">
    <link rel="stylesheet" href="/css/menuCSS/menu.css">
    <link rel="stylesheet" href="/css/estoqueCSS/estoque.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        /* ── Passo 3: lista de fornecedores ── */
        .forn-busca {
            margin-bottom: 1.2rem;
        }

            .forn-busca input {
                width: 100%;
                padding: 0.9rem 1.2rem;
                border: 1px solid #dce1e7;
                border-radius: 0.6rem;
                font-size: 1.4rem;
                font-family: 'Segoe UI', sans-serif;
                outline: none;
                transition: border-color 0.2s, box-shadow 0.2s;
                box-sizing: border-box;
            }

                .forn-busca input:focus {
                    border-color: #1e3c72;
                    box-shadow: 0 0 0 0.3rem rgba(30,60,114,0.08);
                }

        .lista-fornecedores {
            max-height: 22rem;
            overflow-y: auto;
            border: 1px solid #eaecf0;
            border-radius: 0.8rem;
            margin-bottom: 1.4rem;
        }

        .forn-item {
            display: flex;
            align-items: center;
            gap: 1.2rem;
            padding: 1.2rem 1.4rem;
            cursor: pointer;
            border-bottom: 1px solid #f0f2f5;
            transition: background 0.15s;
        }

            .forn-item:last-child {
                border-bottom: none;
            }

            .forn-item:hover {
                background: #eef2fb;
            }

            .forn-item.selecionado {
                background: #eff6ff;
                border-left: 3px solid #1e3c72;
            }

        .forn-check {
            font-size: 1.8rem;
            color: #9ca3af;
            flex-shrink: 0;
        }

        .forn-item.selecionado .forn-check {
            color: #1e3c72;
        }

        .forn-info {
            display: flex;
            flex-direction: column;
            gap: 0.2rem;
            flex: 1;
            min-width: 0;
        }

        .forn-nome {
            font-size: 1.4rem;
            font-weight: 600;
            color: #1e3c72;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .forn-cnpj {
            font-size: 1.2rem;
            color: #9ca3af;
        }

        .forn-vazio {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 0.8rem;
            padding: 2.4rem 1.6rem;
            color: #9ca3af;
            font-size: 1.3rem;
            text-align: center;
        }

            .forn-vazio i {
                font-size: 2.8rem;
                color: #d1d5db;
            }

        .painel-preco {
            background: #f0f9ff;
            border: 1px solid #bae6fd;
            border-radius: 0.8rem;
            padding: 1.4rem 1.6rem;
        }

            .painel-preco label {
                font-size: 1.2rem;
                font-weight: 600;
                color: #374151;
                display: block;
                margin-bottom: 0.5rem;
                text-transform: uppercase;
                letter-spacing: 0.04rem;
            }

            .painel-preco input {
                width: 100%;
                padding: 0.9rem 1.2rem;
                border: 1px solid #bae6fd;
                border-radius: 0.6rem;
                font-size: 1.4rem;
                font-family: 'Segoe UI', sans-serif;
                outline: none;
                box-sizing: border-box;
                transition: border-color 0.2s;
            }

                .painel-preco input:focus {
                    border-color: #0284c7;
                    box-shadow: 0 0 0 0.3rem rgba(2,132,199,0.1);
                }

        .step-opcional {
            font-size: 1rem;
            color: #9ca3af;
            font-weight: 400;
            margin-top: 0.3rem;
        }

        /* ── Resumo ── */
        .resumo-card {
            background: #f8fafc;
            border-radius: 0.8rem;
            padding: 1.6rem;
            border: 1px solid #e5e7eb;
        }

        .resumo-secao {
            font-size: 1.1rem;
            font-weight: 700;
            color: #9ca3af;
            text-transform: uppercase;
            letter-spacing: 0.06rem;
            margin: 1.4rem 0 0.8rem;
            padding-bottom: 0.4rem;
            border-bottom: 1px solid #eaecf0;
        }

            .resumo-secao:first-child {
                margin-top: 0;
            }

        .resumo-linha {
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-size: 1.3rem;
            color: #374151;
            padding: 0.3rem 0;
        }

            .resumo-linha strong {
                color: #1e3c72;
                font-weight: 600;
            }

        .resumo-forn-badge {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            background: #eff6ff;
            color: #1e3c72;
            border: 1px solid #bfdbfe;
            border-radius: 0.5rem;
            padding: 0.4rem 1rem;
            font-size: 1.3rem;
            font-weight: 600;
        }
    </style>
</head>
<body>
    <div class="container">
        <div id="menu"></div>
        <main>
            <section class="secao-estoque">
                <div class="cabecalho-tela">
                    <h2>Gerenciamento de Estoque</h2>
                    <div style="display:flex; align-items:center; gap:1.5rem;">
                        <a href="/EstoqueHistorico" class="link-historico">
                            Movimentações Estoque
                        </a>
                        <button class="btn-novo-estoque" onclick="abrirModal()">
                            <i class="bi bi-plus-circle-fill"></i> Novo Item
                        </button>
                    </div>
                </div>

                <div class="table-container">
                    <div class="area-filtro">
                        <input type="text" id="input-termo-busca" class="input-filtro"
                               placeholder="Buscar por produto..." oninput="filtrarTabela()">
                        <div class="filtro-status">
                            <button id="btn-filtro-todos" class="btn-status-filtro" onclick="setFiltroStatus('todos')">Todos</button>
                            <button id="btn-filtro-critico" class="btn-status-filtro" onclick="setFiltroStatus('critico')">Crítico</button>
                            <button id="btn-filtro-normal" class="btn-status-filtro" onclick="setFiltroStatus('normal')">Normal</button>
                        </div>
                    </div>

                    <table class="table-estoque" id="tabela-estoque">
                        <thead>
                            <tr>
                                <th>Ações</th>
                                <th>Status</th>
                                <th>Produto</th>
                                <th>Qtde Atual</th>
                                <th>Est. Mín</th>
                                <th>SKU</th>
                                <th>Categoria</th>
                                <th>Atualização</th>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>

                    <div class="paginacao">
                        <span class="paginacao-info"></span>
                        <div class="paginacao-controles"></div>
                    </div>
                </div>
            </section>
        </main>
    </div>

    <!-- ════════════════════════════════════════
         MODAL: NOVO PRODUTO (WIZARD 4 PASSOS)
    ════════════════════════════════════════ -->
    <div id="modalEstoque" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h3><i class="bi bi-plus-circle-fill"></i> Novo Produto</h3>
                <button class="btn-fechar-modal" onclick="fecharModal()">&times;</button>
            </div>

            <form id="formEstoque">
                <div class="modal-body">
                    <div id="mensagemErro" class="alerta-erro" style="display:none;"></div>

                    <!-- STEPPER — 4 passos -->
                    <div class="stepper">
                        <div class="step active"><div class="step-circle">1</div></div>
                        <div class="step-line"></div>
                        <div class="step"><div class="step-circle">2</div></div>
                        <div class="step-line"></div>
                        <div class="step"><div class="step-circle">3</div></div>
                        <div class="step-line"></div>
                        <div class="step"><div class="step-circle">4</div></div>
                    </div>

                    <!-- ── ETAPA 1: Informações do Produto ── -->
                    <div class="etapa ativa" id="etapa-1">
                        <p class="form-secao">Informações do Produto</p>
                        <div class="form-grid">
                            <div class="form-group">
                                <label>SKU / Código Interno</label>
                                <input type="text" id="codProduto" placeholder="ex: SKU-001">
                            </div>
                            <div class="form-group form-col-2">
                                <label>Nome <span class="obrigatorio">*</span></label>
                                <input type="text" id="nome" required placeholder="Nome do produto">
                            </div>
                            <div class="form-group form-col-2">
                                <label>Descrição</label>
                                <input type="text" id="descricao" placeholder="Descrição breve">
                            </div>
                            <div class="form-group">
                                <label>Código de Barras <span class="obrigatorio">*</span></label>
                                <input type="text" id="codBarras" required placeholder="EAN / GTIN">
                            </div>
                            <div class="form-group">
                                <label>Categoria <span class="obrigatorio">*</span></label>
                                <select id="prod-categoria">
                                    <option value="">Selecione...</option>
                                </select>
                            </div>
                            <div class="form-group">
                                <label>Preço de Custo (R$)</label>
                                <input type="number" id="precoCusto" step="0.01" placeholder="0,00">
                            </div>
                            <div class="form-group">
                                <label>Preço de Venda (R$)</label>
                                <input type="number" id="precoVenda" step="0.01" placeholder="0,00">
                            </div>
                            <div class="form-group">
                                <label>Unidade</label>
                                <input type="text" id="unidade" placeholder="ex: UN, KG, CX">
                            </div>
                        </div>
                    </div>

                    <!-- ── ETAPA 2: Controle de Estoque ── -->
                    <div class="etapa" id="etapa-2">
                        <p class="form-secao">Controle de Estoque</p>
                        <div class="form-grid">
                            <div class="form-group">
                                <label>Qtd Inicial <span class="obrigatorio">*</span></label>
                                <input type="number" id="qtd" min="0" placeholder="0">
                            </div>
                            <div class="form-group">
                                <label>Estoque Mín <span class="obrigatorio">*</span></label>
                                <input type="number" id="min" min="0" placeholder="0">
                            </div>
                            <div class="form-group">
                                <label>Estoque Máx</label>
                                <input type="number" id="max" min="0" placeholder="0">
                            </div>
                            <div class="form-group">
                                <label>Local</label>
                                <input type="text" id="local" placeholder="ex: Prateleira A1">
                            </div>
                        </div>
                    </div>

                    <!-- ── ETAPA 3: Fornecedor (opcional) ── -->
                    <div class="etapa" id="etapa-3">
                        <p class="form-secao">
                            Associar Fornecedor
                            <span class="step-opcional">(opcional)</span>
                        </p>

                        <div class="forn-busca">
                            <input type="text" id="busca-fornecedor"
                                   placeholder="Buscar por nome ou CNPJ...">
                        </div>

                        <div class="lista-fornecedores" id="lista-fornecedores">
                            <!-- preenchido por JS -->
                        </div>

                        <!-- Painel de preço — aparece ao selecionar fornecedor -->
                        <div id="painel-preco-compra" class="painel-preco" style="display:none">
                            <label>Preço de Compra deste Fornecedor (R$)</label>
                            <input type="number" id="preco-compra" min="0" step="0.01" placeholder="0,00">
                        </div>
                    </div>

                    <!-- ── ETAPA 4: Resumo ── -->
                    <div class="etapa" id="etapa-4">
                        <p class="form-secao">Confirmar Cadastro</p>
                        <div class="resumo-card">

                            <div class="resumo-secao">Produto</div>
                            <div class="resumo-linha">
                                <span>Nome</span>
                                <strong id="resumo-nome">—</strong>
                            </div>
                            <div class="resumo-linha">
                                <span>Código de Barras</span>
                                <strong id="resumo-cod">—</strong>
                            </div>
                            <div class="resumo-linha">
                                <span>Categoria</span>
                                <strong id="resumo-categoria">—</strong>
                            </div>
                            <div class="resumo-linha">
                                <span>Preço de Venda</span>
                                <strong id="resumo-preco-venda">—</strong>
                            </div>

                            <div class="resumo-secao">Estoque</div>
                            <div class="resumo-linha">
                                <span>Qtd Inicial</span>
                                <strong id="resumo-qtd">—</strong>
                            </div>
                            <div class="resumo-linha">
                                <span>Estoque Mínimo</span>
                                <strong id="resumo-min">—</strong>
                            </div>

                            <!-- Bloco de fornecedor — oculto se não selecionado -->
                            <div id="resumo-bloco-fornecedor" style="display:none">
                                <div class="resumo-secao">Fornecedor</div>
                                <div class="resumo-linha">
                                    <span>Fornecedor</span>
                                    <span class="resumo-forn-badge">
                                        <i class="bi bi-building"></i>
                                        <span id="resumo-fornecedor">—</span>
                                    </span>
                                </div>
                                <div class="resumo-linha">
                                    <span>Preço de Compra</span>
                                    <strong id="resumo-preco-compra">—</strong>
                                </div>
                            </div>

                        </div>
                    </div>

                </div><!-- /modal-body -->

                <div class="modal-footer">
                    <button type="button" class="btn-secundario" id="btn-voltar" style="display:none">
                        <i class="bi bi-arrow-left"></i> Voltar
                    </button>
                    <button type="button" class="btn-primario" id="btn-proximo">
                        Próximo <i class="bi bi-arrow-right"></i>
                    </button>
                    <button type="button" class="btn-primario" id="btnSalvar" style="display:none">
                        <i class="bi bi-check-lg"></i> Confirmar e Salvar
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- MODAL: MOVIMENTAÇÃO -->
    <div class="modal" id="modal-movimentacao">
        <div class="modal-content" style="width:44rem">
            <div class="modal-header">
                <h3><i class="bi bi-arrow-left-right"></i> Movimentar Estoque</h3>
                <button class="btn-fechar-modal" onclick="fecharModalMovimentacao()">&times;</button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="mov-idProduto">
                <p class="form-secao">Produto</p>
                <p id="mov-produto-nome" style="font-size:1.5rem; font-weight:600; color:#1e3c72; margin-bottom:1.6rem;"></p>
                <div class="form-grid">
                    <div class="form-group">
                        <label>Tipo <span class="obrigatorio">*</span></label>
                        <select id="mov-tipo">
                            <option value="ENTRADA">Entrada</option>
                            <option value="SAIDA">Saída</option>
                            <option value="AJUSTE">Ajuste</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Quantidade <span class="obrigatorio">*</span></label>
                        <input type="number" id="mov-quantidade" min="1" placeholder="0">
                    </div>
                    <div class="form-group form-col-2">
                        <label>Motivo / Observação</label>
                        <input type="text" id="mov-motivo" placeholder="Ex: Compra fornecedor...">
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn-secundario" onclick="fecharModalMovimentacao()">Cancelar</button>
                <button type="button" class="btn-primario" onclick="salvarMovimentacao()">
                    <i class="bi bi-check-lg"></i> Confirmar
                </button>
            </div>
        </div>
    </div>

    <!-- MODAL: ESTOQUE MÍNIMO -->
    <div class="modal" id="modal-minimo">
        <div class="modal-content" style="width:36rem">
            <div class="modal-header">
                <h3><i class="bi bi-pencil-fill"></i> Estoque Mínimo</h3>
                <button class="btn-fechar-modal" onclick="fecharModalMinimo()">&times;</button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="min-idProduto">
                <div class="form-group">
                    <label>Novo Estoque Mínimo <span class="obrigatorio">*</span></label>
                    <input type="number" id="min-valor" min="0" placeholder="0">
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn-secundario" onclick="fecharModalMinimo()">Cancelar</button>
                <button type="button" class="btn-primario" onclick="salvarMinimo()">
                    <i class="bi bi-check-lg"></i> Salvar
                </button>
            </div>
        </div>
    </div>

    <script src="/js/menuJS/menu.js"></script>
    <script src="/js/shared/flexValidation.js"></script>
    <script src="/js/estoqueJS/estoque.js"></script>
</body>
</html>
