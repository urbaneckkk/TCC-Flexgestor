<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Estoque - FlexGestor</title>
    <link rel="stylesheet" href="/css/homeCSS/home.css">
    <link rel="stylesheet" href="/css/menuCSS/menu.css">
    <link rel="stylesheet" href="/css/estoqueCSS/estoque.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>

<body>
    <div class="container">
        <div id="menu"></div>

        <main>
            <section class="secao-estoque">
                <div class="cabecalho-tela">
                    <h2>Gerenciamento de Estoque</h2>

                    <div style="display:flex; align-items:center; gap:1.5rem;">

                        <!-- 🔥 LINK HISTÓRICO -->
                        <a href="/WebApplication5/Views/EstoqueHistorico/index.html" class="link-historico">
                            Movimentações Estoque
                        </a>


                    </div>
                </div>

                <div class="table-container">
                    <div class="area-filtro">
                        <input type="text" id="input-termo-busca" class="input-filtro"
                               placeholder="Buscar por produto ou local..." oninput="filtrarTabela()">
                        <div class="filtro-status">
                            <button id="btn-filtro-todos" class="btn-status-filtro"
                                    onclick="setFiltroStatus('todos')">
                                Todos
                            </button>
                            <button id="btn-filtro-critico" class="btn-status-filtro"
                                    onclick="setFiltroStatus('critico')">
                                Crítico
                            </button>
                            <button id="btn-filtro-normal" class="btn-status-filtro"
                                    onclick="setFiltroStatus('normal')">
                                Normal
                            </button>
                        </div>
                    </div>

                    <table class="table-estoque" id="tabela-estoque">
                        <thead>
                            <tr>
                                <th>Ações</th>
                                <th>Status</th>
                                <th>Produto</th>
                                <th>Qtde Atual</th>
                                <th>Est. Mín</th>
                                <th>Est. Máx</th>
                                <th>Local</th>
                                <th>Atualização</th>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>

                    <div class="paginacao">
                        <span class="paginacao-info"></span>
                        <div class="paginacao-controles"></div>
                    </div>
                </div>
            </section>
        </main>
    </div>

    <div id="modalEstoque" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h3 id="modalTitulo">Novo Item</h3>
                <button class="btn-fechar-modal" onclick="fecharModal()">&times;</button>
            </div>

            <form id="formEstoque">
                <div class="modal-body">
                    <div id="mensagemErro" class="alerta-erro" style="display:none;">
                        Preencha os campos obrigatórios.
                    </div>

                    <!-- STEPPER -->
                    <div class="stepper">
                        <div class="step">
                            <div class="step-circle">1</div>
                        </div>
                        <div class="step-line"></div>

                        <div class="step">
                            <div class="step-circle">2</div>
                        </div>
                        <div class="step-line"></div>

                        <div class="step">
                            <div class="step-circle">3</div>
                        </div>
                    </div>

                    <!-- ETAPA 1 -->
                    <div class="etapa ativa" id="etapa-1">
                        <p class="form-secao">Informações do Produto</p>

                        <div class="form-grid">

                            <div class="form-group">
                                <label>Código</label>
                                <input type="text" id="codProduto">
                            </div>

                            <div class="form-group form-col-2">
                                <label>Nome <span class="obrigatorio">*</span></label>
                                <input type="text" id="nome" required>
                            </div>

                            <div class="form-group form-col-2">
                                <label>Descrição</label>
                                <input type="text" id="descricao">
                            </div>

                            <div class="form-group">
                                <label>Código de Barras <span class="obrigatorio">*</span></label>
                                <input type="text" id="codBarras" required>
                            </div>

                            <div class="form-group">
                                <label>Categoria</label>
                                <select id="categoria">
                                    <option value="">Selecione...</option>
                                    <option value="1">Peças</option>
                                    <option value="2">Máquinas</option>
                                    <option value="3">Insumos</option>
                                </select>
                            </div>

                            <div class="form-group">
                                <label>Preço Custo</label>
                                <input type="number" id="precoCusto" step="0.01">
                            </div>

                            <div class="form-group">
                                <label>Preço Venda</label>
                                <input type="number" id="precoVenda" step="0.01">
                            </div>

                            <div class="form-group">
                                <label>Unidade</label>
                                <input type="text" id="unidade">
                            </div>

                            <div class="form-group">
                                <label>Tributação (%)</label>
                                <input type="number" id="tributacao" step="0.01">
                            </div>

                        </div>
                    </div>

                    <!-- ETAPA 2 -->
                    <div class="etapa" id="etapa-2">
                        <p class="form-secao">Controle de Estoque</p>

                        <div class="form-grid">
                            <div class="form-group">
                                <label>Qtd Atual</label>
                                <input type="number" id="qtd">
                            </div>

                            <div class="form-group">
                                <label>Estoque Mín</label>
                                <input type="number" id="min">
                            </div>

                            <div class="form-group">
                                <label>Estoque Máx</label>
                                <input type="number" id="max">
                            </div>

                            <div class="form-group">
                                <label>Local</label>
                                <input type="text" id="local">
                            </div>
                        </div>
                    </div>

                    <!-- ETAPA 3 -->
                    <!-- ===================== -->
                    <!-- ETAPA 3 - FORNECEDOR + LOTE -->
                    <!-- ===================== -->
                    <div class="etapa" id="etapa-3">
                        <p class="form-secao">Fornecedor</p>

                        <div class="form-grid">
                            <div class="form-group form-col-2">
                                <label>Fornecedor <span class="obrigatorio">*</span></label>
                                <select id="fornecedor" required>
                                    <option value="">Selecione...</option>
                                    <option value="1">Fornecedor A</option>
                                    <option value="2">Fornecedor B</option>
                                </select>
                            </div>
                        </div>

                        <p class="form-secao">Informações do Lote</p>

                        <div class="form-grid">

                            <div class="form-group">
                                <label>Nº do Lote <span class="obrigatorio">*</span></label>
                                <input type="text" id="numeroLote" required>
                            </div>

                            <div class="form-group">
                                <label>Data Fabricação <span class="obrigatorio">*</span></label>
                                <input type="date" id="dthFabricacao" required>
                            </div>

                            <div class="form-group">
                                <label>Data Validade</label>
                                <input type="date" id="dthValidade">
                            </div>

                            <div class="form-group">
                                <label>Data Entrada <span class="obrigatorio">*</span></label>
                                <input type="date" id="dthEntrada" required>
                            </div>

                            <div class="form-group">
                                <label>Qtd Inicial <span class="obrigatorio">*</span></label>
                                <input type="number" id="qtdInicial" required>
                            </div>

                            <div class="form-group">
                                <label>Qtd Atual <span class="obrigatorio">*</span></label>
                                <input type="number" id="qtdAtualLote" required>
                            </div>

                            <div class="form-group">
                                <label>Custo Unitário</label>
                                <input type="number" id="custoUnit" step="0.01">
                            </div>

                        </div>
                    </div>

                </div>

                <div class="modal-footer">
                    <button type="button" class="btn-secundario" onclick="voltarEtapa()">Voltar</button>
                    <button type="button" class="btn-primario" onclick="proximaEtapa()">Próximo</button>
                    <button type="submit" class="btn-primario" id="btnSalvar" style="display:none;">Salvar</button>
                </div>
            </form>
        </div>
    </div>

    <div class="modal" id="modal-edicao">...</div>
    <!-- MODAL CONFIRMAÇÃO -->
    <div id="modal-confirmar" class="modal">
        <div class="modal-content" style="width: 40rem;">

            <div class="confirm-body">
                <div class="confirm-icone">
                    <i class="bi bi-exclamation-triangle"></i>
                </div>

                <p id="confirm-mensagem">
                    Deseja confirmar esta ação?
                </p>
            </div>

            <div class="modal-footer">
                <button class="btn-secundario" onclick="fecharModal('modal-confirmar')">
                    Cancelar
                </button>

                <button class="btn-perigo" id="btnConfirmarAcao">
                    Confirmar
                </button>
            </div>

        </div>
    </div>

    <!-- ════════════════════════════════════════
         MODAL: MOVIMENTAÇÃO DE ESTOQUE
         Substitui o modal antigo de "Novo Item" (modalEstoque)
         Cole antes do </body>
    ════════════════════════════════════════ -->
    <div class="modal" id="modal-movimentacao">
        <div class="modal-content" style="width:44rem">
            <div class="modal-header">
                <h3><i class="bi bi-arrow-left-right"></i> Movimentar Estoque</h3>
                <button class="btn-fechar-modal" onclick="fecharModalMovimentacao()">&times;</button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="mov-idProduto">

                <p class="form-secao">Produto</p>
                <p id="mov-produto-nome" style="font-size:1.5rem; font-weight:600; color:#1e3c72; margin-bottom:1.6rem;"></p>

                <div class="form-grid">
                    <div class="form-group">
                        <label>Tipo <span class="obrigatorio">*</span></label>
                        <select id="mov-tipo">
                            <option value="ENTRADA">Entrada</option>
                            <option value="SAIDA">Saída</option>
                            <option value="AJUSTE">Ajuste</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Quantidade <span class="obrigatorio">*</span></label>
                        <input type="number" id="mov-quantidade" min="1" placeholder="0">
                    </div>
                    <div class="form-group form-col-2">
                        <label>Motivo / Observação</label>
                        <input type="text" id="mov-motivo" placeholder="Ex: Compra fornecedor, Venda pedido...">
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn-secundario" onclick="fecharModalMovimentacao()">Cancelar</button>
                <button type="button" class="btn-primario" onclick="salvarMovimentacao()">
                    <i class="bi bi-check-lg"></i> Confirmar
                </button>
            </div>
        </div>
    </div>

    <!-- ════════════════════════════════════════
         MODAL: ATUALIZAR ESTOQUE MÍNIMO
    ════════════════════════════════════════ -->
    <div class="modal" id="modal-minimo">
        <div class="modal-content" style="width:36rem">
            <div class="modal-header">
                <h3><i class="bi bi-pencil-fill"></i> Estoque Mínimo</h3>
                <button class="btn-fechar-modal" onclick="fecharModalMinimo()">&times;</button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="min-idProduto">
                <div class="form-group">
                    <label>Novo Estoque Mínimo <span class="obrigatorio">*</span></label>
                    <input type="number" id="min-valor" min="0" placeholder="0">
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn-secundario" onclick="fecharModalMinimo()">Cancelar</button>
                <button type="button" class="btn-primario" onclick="salvarMinimo()">
                    <i class="bi bi-check-lg"></i> Salvar
                </button>
            </div>
        </div>
    </div>

    <script src="/js/menuJS/menu.js"></script>
    <script src="/js/estoqueJS/estoque.js"></script>
</body>

</html>