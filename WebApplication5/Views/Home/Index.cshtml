@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Página Inicial";
}

@section styles {
    <link rel="stylesheet" href="/css/home.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
}

<main>
    <h2>Bem-vindo, @(ViewBag.NomeUsuario ?? "Usuário")!</h2>

    <div class="cards">

        <!-- Ticket Médio -->
        <div class="card">
            <div class="card-topo">
                <span class="kpi-label">Ticket Médio</span>
                <div class="kpi-icon kpi-icon-verde">
                    <i class="bi bi-graph-up-arrow"></i>
                </div>
            </div>
            <div class="kpi-valor kpi-valor-verde" id="ticketMedio">-</div>
            <p class="kpi-sub">Média por venda este mês</p>
            <div class="kpi-barra-label">
                <span>Meta</span>
                <span id="ticketPercent">-</span>
            </div>
            <div class="kpi-barra">
                <div class="kpi-barra-fill fill-verde" id="ticketBarra" style="width:0%"></div>
            </div>
            <div class="card-rodape">
                <span class="kpi-variacao positiva" id="ticketVariacao"></span>
                <span class="kpi-periodo">Atual</span>
            </div>
        </div>

        <!-- Clientes Ativos -->
        <div class="card">
            <div class="card-topo">
                <span class="kpi-label">Clientes Ativos</span>
                <div class="kpi-icon kpi-icon-azul">
                    <i class="bi bi-people-fill"></i>
                </div>
            </div>
            <div class="kpi-valor" id="clientesAtivos">-</div>
            <p class="kpi-sub" id="clientesTotal">-</p>
            <div class="kpi-barra-label">
                <span>Taxa</span>
                <span id="clientesPercent">-</span>
            </div>
            <div class="kpi-barra">
                <div class="kpi-barra-fill fill-azul" id="clientesBarra" style="width:0%"></div>
            </div>
            <div class="card-rodape">
                <span class="kpi-variacao positiva" id="clientesVariacao"></span>
                <span class="kpi-periodo">Atual</span>
            </div>
        </div>

        <!-- Usuários -->
        <div class="card">
            <div class="card-topo">
                <span class="kpi-label">Usuários</span>
                <div class="kpi-icon kpi-icon-ciano">
                    <i class="bi bi-person-badge-fill"></i>
                </div>
            </div>
            <div class="kpi-valor kpi-valor-ciano" id="totalUsuarios">-</div>
            <p class="kpi-sub">Total no sistema</p>
            <div class="kpi-barra-label">
                <span>Atividade</span>
                <span id="usuariosPercent">-</span>
            </div>
            <div class="kpi-barra">
                <div class="kpi-barra-fill fill-ciano" id="usuariosBarra" style="width:0%"></div>
            </div>
            <div class="card-rodape">
                <span class="kpi-variacao neutra">Sem alterações</span>
                <span class="kpi-periodo">Atual</span>
            </div>
        </div>

        <!-- Empresas -->
        <div class="card">
            <div class="card-topo">
                <span class="kpi-label">Empresas</span>
                <div class="kpi-icon kpi-icon-roxo">
                    <i class="bi bi-building"></i>
                </div>
            </div>
            <div class="kpi-valor kpi-valor-roxo" id="totalEmpresas">-</div>
            <p class="kpi-sub">Empresas cadastradas</p>
            <div class="kpi-barra-label">
                <span>Crescimento</span>
                <span>-</span>
            </div>
            <div class="kpi-barra">
                <div class="kpi-barra-fill fill-roxo" style="width:60%"></div>
            </div>
            <div class="card-rodape">
                <span class="kpi-variacao positiva">+ crescimento</span>
                <span class="kpi-periodo">Atual</span>
            </div>
        </div>

    </div>
</main>

@section scripts {
    <script>
        async function carregarDashboard() {
            try {
                const [resUsuarios, resEmpresas] = await Promise.all([
                    fetch('/Usuario/Total'),
                    fetch('/Empresa/Total')
                ]);

                if (resUsuarios.ok) {
                    const total = await resUsuarios.text();
                    document.getElementById('totalUsuarios').textContent = total;

                    // exemplo simples de % fake
                    document.getElementById('usuariosPercent').textContent = "80%";
                    document.getElementById('usuariosBarra').style.width = "80%";
                }

                if (resEmpresas.ok) {
                    const total = await resEmpresas.text();
                    document.getElementById('totalEmpresas').textContent = total;
                }

                // MOCK (depois você liga na API real)
                document.getElementById('ticketMedio').textContent = "R$ 312,50";
                document.getElementById('ticketPercent').textContent = "89%";
                document.getElementById('ticketBarra').style.width = "89%";
                document.getElementById('ticketVariacao').innerHTML = '<i class="bi bi-arrow-up-short"></i> +5%';

                document.getElementById('clientesAtivos').textContent = "248";
                document.getElementById('clientesTotal').textContent = "de 261 cadastrados";
                document.getElementById('clientesPercent').textContent = "95%";
                document.getElementById('clientesBarra').style.width = "95%";
                document.getElementById('clientesVariacao').innerHTML = '<i class="bi bi-arrow-up-short"></i> +12 novos';

            } catch (e) {
                console.error(e);
            }
        }

        carregarDashboard();
    </script>
}