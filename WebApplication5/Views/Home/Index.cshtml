@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Home";
}

@section styles {
    <style>
        .greeting {
            margin-bottom: 28px;
            animation: fadeUp 0.5s ease both;
        }

            .greeting h2 {
                font-family: 'Syne', sans-serif;
                font-weight: 800;
                font-size: 1.8rem;
                line-height: 1.2;
            }

                .greeting h2 span {
                    background: linear-gradient(135deg, var(--accent), var(--accent2));
                    -webkit-background-clip: text;
                    -webkit-text-fill-color: transparent;
                }

            .greeting p {
                color: var(--muted);
                font-size: 0.88rem;
                margin-top: 6px;
            }

        .cards-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 14px;
            margin-bottom: 28px;
        }

        .card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 13px;
            padding: 20px;
            animation: fadeUp 0.5s ease both;
            transition: border-color 0.2s, transform 0.2s;
        }

            .card:hover {
                border-color: var(--accent);
                transform: translateY(-2px);
            }

            .card:nth-child(1) {
                animation-delay: 0.05s;
            }

            .card:nth-child(2) {
                animation-delay: 0.1s;
            }

        .card-icon {
            width: 38px;
            height: 38px;
            border-radius: 9px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 12px;
        }

            .card-icon svg {
                width: 16px;
                height: 16px;
            }

            .card-icon.blue {
                background: rgba(79,142,255,0.15);
                color: var(--accent);
            }

            .card-icon.purple {
                background: rgba(167,139,250,0.15);
                color: var(--accent2);
            }

        .card-value {
            font-family: 'Syne', sans-serif;
            font-size: 1.8rem;
            font-weight: 800;
            line-height: 1;
            margin-bottom: 4px;
        }

        .card-label {
            font-size: 0.78rem;
            color: var(--muted);
        }

        .card-trend {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            font-size: 0.7rem;
            font-weight: 500;
            margin-top: 10px;
            padding: 3px 8px;
            border-radius: 20px;
            background: rgba(52,211,153,0.12);
            color: var(--success);
        }

        .section-title {
            font-family: 'Syne', sans-serif;
            font-weight: 700;
            font-size: 0.95rem;
            margin-bottom: 14px;
        }

        .quick-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
            gap: 10px;
        }

        .quick-btn {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 11px;
            padding: 16px;
            display: flex;
            flex-direction: column;
            align-items: flex-start;
            gap: 7px;
            text-decoration: none;
            color: var(--text);
            transition: all 0.2s;
            animation: fadeUp 0.5s ease both;
        }

            .quick-btn:hover {
                border-color: var(--accent);
                background: rgba(79,142,255,0.05);
                transform: translateY(-2px);
            }

            .quick-btn svg {
                width: 18px;
                height: 18px;
                color: var(--accent);
            }

            .quick-btn span {
                font-size: 0.8rem;
                font-weight: 500;
            }

            .quick-btn small {
                font-size: 0.7rem;
                color: var(--muted);
            }
    </style>
}

<div class="greeting">
    <h2>Ola, <span>@(ViewBag.NomeUsuario ?? "Usuario")</span> !</h2>
    <p>Aqui esta um resumo do sistema hoje.</p>
</div>

<div class="cards-grid">
    <div class="card">
        <div class="card-icon blue">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
        </div>
        <div class="card-value" id="totalUsuarios">-</div>
        <div class="card-label">Usuarios ativos</div>
        <div class="card-trend">atualizado agora</div>
    </div>
    <div class="card">
        <div class="card-icon purple">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" /></svg>
        </div>
        <div class="card-value" id="totalEmpresas">-</div>
        <div class="card-label">Empresas cadastradas</div>
        <div class="card-trend">atualizado agora</div>
    </div>
</div>

<div class="section-title">Acesso rapido</div>
<div class="quick-grid">
    <a href="/Usuario" class="quick-btn">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z" /></svg>
        <span>Novo Usuario</span>
        <small>Cadastrar usuario</small>
    </a>
    <a href="/Empresa" class="quick-btn">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3m0 0v3m0-3h3m-3 0H9m12 0a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
        <span>Nova Empresa</span>
        <small>Cadastrar empresa</small>
    </a>
    <a href="/ML" class="quick-btn">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
        <span>Previsoes ML</span>
        <small>Inteligencia de vendas</small>
    </a>
</div>

@section scripts {
    <script>
        async function carregarTotais() {
            try {
                const [resU, resE] = await Promise.all([fetch('/Usuario/Total'), fetch('/Empresa/Total')]);
                if (resU.ok) document.getElementById('totalUsuarios').textContent = await resU.text();
                if (resE.ok) document.getElementById('totalEmpresas').textContent = await resE.text();
            } catch {}
        }
        carregarTotais();
    </script>
}