@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Dashboard";
}

<style>
    .greeting {
        animation: fadeUp 0.4s ease both;
    }

        .greeting h2 {
            font-family: 'Syne', sans-serif;
            font-weight: 800;
            font-size: 1.7rem;
        }

            .greeting h2 span {
                background: linear-gradient(135deg, var(--accent), var(--accent2));
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
            }

        .greeting p {
            color: var(--muted);
            font-size: 0.85rem;
            margin-top: 4px;
        }

    .cards-row {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 14px;
        animation: fadeUp 0.4s ease 0.05s both;
    }

    .stat-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 20px;
        transition: border-color 0.2s, transform 0.2s;
    }

        .stat-card:hover {
            border-color: var(--accent);
            transform: translateY(-2px);
        }

    .stat-icon {
        width: 36px;
        height: 36px;
        border-radius: 9px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 12px;
    }

        .stat-icon svg {
            width: 16px;
            height: 16px;
        }

        .stat-icon.blue {
            background: rgba(79,142,255,0.12);
            color: var(--accent);
        }

        .stat-icon.purple {
            background: rgba(167,139,250,0.12);
            color: var(--accent2);
        }

        .stat-icon.green {
            background: rgba(52,211,153,0.12);
            color: var(--success);
        }

    .stat-value {
        font-family: 'Syne', sans-serif;
        font-size: 1.8rem;
        font-weight: 800;
        line-height: 1;
    }

    .stat-label {
        font-size: 0.77rem;
        color: var(--muted);
        margin-top: 4px;
    }

    .section-label {
        font-family: 'Syne', sans-serif;
        font-weight: 700;
        font-size: 0.9rem;
        margin-bottom: 12px;
        color: var(--text);
    }

    .quick-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
        gap: 10px;
        animation: fadeUp 0.4s ease 0.1s both;
    }

    .quick-btn {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 10px;
        padding: 16px;
        display: flex;
        flex-direction: column;
        gap: 7px;
        text-decoration: none;
        color: var(--text);
        transition: all 0.18s;
    }

        .quick-btn:hover {
            border-color: var(--accent);
            background: rgba(79,142,255,0.04);
            transform: translateY(-1px);
        }

        .quick-btn svg {
            width: 18px;
            height: 18px;
            color: var(--accent);
        }

        .quick-btn span {
            font-size: 0.82rem;
            font-weight: 500;
        }

        .quick-btn small {
            font-size: 0.7rem;
            color: var(--muted);
        }
</style>

<div class="greeting">
    <h2>Olá, <span>@(ViewBag.NomeUsuario ?? "Usuário")</span> 👋</h2>
    <p>Aqui está um resumo do sistema hoje.</p>
</div>

<div class="cards-row">
    <div class="stat-card">
        <div class="stat-icon blue">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
        </div>
        <div class="stat-value" id="totalUsuarios">—</div>
        <div class="stat-label">Usuários ativos</div>
    </div>
    <div class="stat-card">
        <div class="stat-icon purple">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" /></svg>
        </div>
        <div class="stat-value" id="totalEmpresas">—</div>
        <div class="stat-label">Empresas cadastradas</div>
    </div>
    <div class="stat-card">
        <div class="stat-icon green">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>
        </div>
        <div class="stat-value" id="totalClientes">—</div>
        <div class="stat-label">Clientes ativos</div>
    </div>
</div>

<div>
    <div class="section-label">Acesso rápido</div>
    <div class="quick-grid">
        <a href="/Usuario" class="quick-btn">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z" /></svg>
            <span>Usuários</span>
            <small>Gerenciar usuários</small>
        </a>
        <a href="/Cliente" class="quick-btn">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>
            <span>Clientes</span>
            <small>Gerenciar clientes</small>
        </a>
        <a href="/Empresa" class="quick-btn">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" /></svg>
            <span>Empresas</span>
            <small>Gerenciar empresas</small>
        </a>
    </div>
</div>

@section scripts {
    <script>
        async function carregarTotais() {
            try {
                const [resU, resE, resC] = await Promise.all([
                    fetch('/Usuario/Total'),
                    fetch('/Empresa/Total'),
                    fetch('/Cliente/Total')
                ]);
                if (resU.ok) document.getElementById('totalUsuarios').textContent = await resU.text();
                if (resE.ok) document.getElementById('totalEmpresas').textContent = await resE.text();
                if (resC.ok) document.getElementById('totalClientes').textContent = await resC.text();
            } catch {}
        }
        carregarTotais();
    </script>
}
