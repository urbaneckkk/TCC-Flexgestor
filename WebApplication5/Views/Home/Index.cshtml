<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>FlexGestor — Home</title>
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        :root {
            --bg: #0d0f14;
            --surface: #151820;
            --surface2: #1c2030;
            --accent: #4f8eff;
            --accent2: #a78bfa;
            --text: #e8ecf4;
            --muted: #6b7491;
            --border: #242840;
            --success: #34d399;
            --warning: #fbbf24;
            --danger: #f87171;
        }

        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--bg);
            color: var(--text);
            min-height: 100vh;
            display: flex;
        }

        .sidebar {
            width: 240px;
            min-height: 100vh;
            background: var(--surface);
            border-right: 1px solid var(--border);
            display: flex;
            flex-direction: column;
            position: fixed;
            top: 0;
            left: 0;
            z-index: 100;
        }

        .sidebar-logo {
            padding: 28px 24px 20px;
            border-bottom: 1px solid var(--border);
        }

            .sidebar-logo h1 {
                font-family: 'Syne', sans-serif;
                font-weight: 800;
                font-size: 1.3rem;
                background: linear-gradient(135deg, var(--accent), var(--accent2));
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
            }

            .sidebar-logo span {
                font-size: 0.72rem;
                color: var(--muted);
                font-weight: 300;
                letter-spacing: 0.05em;
            }

        .sidebar-nav {
            padding: 16px 12px;
            flex: 1;
        }

        .nav-label {
            font-size: 0.65rem;
            color: var(--muted);
            letter-spacing: 0.12em;
            text-transform: uppercase;
            padding: 8px 12px 6px;
            font-weight: 500;
        }

        .nav-item {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px 12px;
            border-radius: 8px;
            color: var(--muted);
            text-decoration: none;
            font-size: 0.875rem;
            transition: all 0.15s;
            margin-bottom: 2px;
        }

            .nav-item:hover {
                background: var(--surface2);
                color: var(--text);
            }

            .nav-item.active {
                background: rgba(79,142,255,0.12);
                color: var(--accent);
            }

            .nav-item svg {
                width: 16px;
                height: 16px;
                flex-shrink: 0;
            }

        .sidebar-footer {
            padding: 16px 12px;
            border-top: 1px solid var(--border);
        }

        .user-card {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px 12px;
            border-radius: 8px;
            background: var(--surface2);
        }

        .user-avatar {
            width: 32px;
            height: 32px;
            border-radius: 8px;
            background: linear-gradient(135deg, var(--accent), var(--accent2));
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Syne', sans-serif;
            font-weight: 700;
            font-size: 0.8rem;
            color: white;
            flex-shrink: 0;
        }

        .user-info {
            flex: 1;
            min-width: 0;
        }

        .user-name {
            font-size: 0.8rem;
            font-weight: 500;
            color: var(--text);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .user-role {
            font-size: 0.68rem;
            color: var(--muted);
        }

        .logout-btn {
            background: none;
            border: none;
            cursor: pointer;
            color: var(--muted);
            padding: 4px;
            display: flex;
            transition: color 0.15s;
        }

            .logout-btn:hover {
                color: var(--danger);
            }

            .logout-btn svg {
                width: 14px;
                height: 14px;
            }

        .main {
            margin-left: 240px;
            flex: 1;
            display: flex;
            flex-direction: column;
        }

        .topbar {
            height: 60px;
            background: var(--surface);
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            padding: 0 32px;
            position: sticky;
            top: 0;
            z-index: 50;
        }

        .topbar-title {
            font-family: 'Syne', sans-serif;
            font-weight: 700;
            font-size: 1rem;
            flex: 1;
        }

        .content {
            padding: 32px;
            flex: 1;
        }

        .greeting {
            margin-bottom: 32px;
            animation: fadeUp 0.5s ease both;
        }

            .greeting h2 {
                font-family: 'Syne', sans-serif;
                font-weight: 800;
                font-size: 1.9rem;
                line-height: 1.2;
            }

                .greeting h2 span {
                    background: linear-gradient(135deg, var(--accent), var(--accent2));
                    -webkit-background-clip: text;
                    -webkit-text-fill-color: transparent;
                }

            .greeting p {
                color: var(--muted);
                font-size: 0.9rem;
                margin-top: 6px;
            }

        .cards-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 16px;
            margin-bottom: 32px;
        }

        .card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 14px;
            padding: 22px;
            animation: fadeUp 0.5s ease both;
            transition: border-color 0.2s, transform 0.2s;
        }

            .card:hover {
                border-color: var(--accent);
                transform: translateY(-2px);
            }

            .card:nth-child(1) {
                animation-delay: 0.05s;
            }

            .card:nth-child(2) {
                animation-delay: 0.1s;
            }

        .card-icon {
            width: 40px;
            height: 40px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 14px;
        }

            .card-icon svg {
                width: 18px;
                height: 18px;
            }

            .card-icon.blue {
                background: rgba(79,142,255,0.15);
                color: var(--accent);
            }

            .card-icon.purple {
                background: rgba(167,139,250,0.15);
                color: var(--accent2);
            }

        .card-value {
            font-family: 'Syne', sans-serif;
            font-size: 1.9rem;
            font-weight: 800;
            line-height: 1;
            margin-bottom: 4px;
        }

        .card-label {
            font-size: 0.8rem;
            color: var(--muted);
        }

        .card-trend {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            font-size: 0.72rem;
            font-weight: 500;
            margin-top: 10px;
            padding: 3px 8px;
            border-radius: 20px;
            background: rgba(52,211,153,0.12);
            color: var(--success);
        }

        .section-title {
            font-family: 'Syne', sans-serif;
            font-weight: 700;
            font-size: 1rem;
            margin-bottom: 16px;
        }

        .quick-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
            gap: 12px;
        }

        .quick-btn {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 18px;
            display: flex;
            flex-direction: column;
            align-items: flex-start;
            gap: 8px;
            cursor: pointer;
            text-decoration: none;
            color: var(--text);
            transition: all 0.2s;
            animation: fadeUp 0.5s ease both;
        }

            .quick-btn:hover {
                border-color: var(--accent);
                background: rgba(79,142,255,0.05);
                transform: translateY(-2px);
            }

            .quick-btn svg {
                width: 20px;
                height: 20px;
                color: var(--accent);
            }

            .quick-btn span {
                font-size: 0.82rem;
                font-weight: 500;
            }

            .quick-btn small {
                font-size: 0.72rem;
                color: var(--muted);
            }

        @@keyframes fadeUp {
            from

        {
            opacity: 0;
            transform: translateY(12px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }

        }
    </style>
</head>
<body>
    <aside class="sidebar">
        <div class="sidebar-logo">
            <h1>FlexGestor</h1>
            <span>Painel de Gestão</span>
        </div>
        <nav class="sidebar-nav">
            <div class="nav-label">Principal</div>
            <a href="/Home" class="nav-item active">
                <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" /></svg>
                Home
            </a>
            <div class="nav-label" style="margin-top:8px">Cadastros</div>
            <a href="/Usuario" class="nav-item">
                <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                Usuários
            </a>
            <a href="/Empresa" class="nav-item">
                <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" /></svg>
                Empresas
            </a>
        </nav>
        <div class="sidebar-footer">
            <div class="user-card">
                <div class="user-avatar">@(ViewBag.NomeUsuario?.ToString().Substring(0, 1).ToUpper() ?? "U")</div>
                <div class="user-info">
                    <div class="user-name">@(ViewBag.NomeUsuario ?? "Usuário")</div>
                    <div class="user-role">Administrador</div>
                </div>
                <a href="/Login/Sair" class="logout-btn" title="Sair">
                    <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" /></svg>
                </a>
            </div>
        </div>
    </aside>

    <div class="main">
        <div class="topbar">
            <div class="topbar-title">Dashboard</div>
        </div>
        <div class="content">
            <div class="greeting">
                <h2>Olá, <span>@(ViewBag.NomeUsuario ?? "Usuário")</span> 👋</h2>
                <p>Aqui está um resumo do sistema hoje.</p>
            </div>
            <div class="cards-grid">
                <div class="card">
                    <div class="card-icon blue">
                        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                    </div>
                    <div class="card-value" id="totalUsuarios">—</div>
                    <div class="card-label">Usuários ativos</div>
                    <div class="card-trend">↑ atualizado agora</div>
                </div>
                <div class="card">
                    <div class="card-icon purple">
                        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" /></svg>
                    </div>
                    <div class="card-value" id="totalEmpresas">—</div>
                    <div class="card-label">Empresas cadastradas</div>
                    <div class="card-trend">↑ atualizado agora</div>
                </div>
            </div>
            <div class="section-title">Acesso rápido</div>
            <div class="quick-grid">
                <a href="/Usuario" class="quick-btn">
                    <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z" /></svg>
                    <span>Novo Usuário</span>
                    <small>Cadastrar usuário</small>
                </a>
                <a href="/Empresa" class="quick-btn">
                    <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3m0 0v3m0-3h3m-3 0H9m12 0a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                    <span>Nova Empresa</span>
                    <small>Cadastrar empresa</small>
                </a>
            </div>
        </div>
    </div>

    <script>
        async function carregarTotais() {
            try {
                const [resU, resE] = await Promise.all([fetch('/Usuario/Total'), fetch('/Empresa/Total')]);
                if (resU.ok) document.getElementById('totalUsuarios').textContent = await resU.text();
                if (resE.ok) document.getElementById('totalEmpresas').textContent = await resE.text();
            } catch { }
        }
        carregarTotais();
    </script>
</body>
</html>