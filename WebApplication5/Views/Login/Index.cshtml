<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/login.css">
    <title>Login</title>
</head>

<body>
    <form action="/Login/Entrar" method="POST">
        <fieldset>
            <h1>FlexGestor</h1>

            <div class="campo">
                <label for="doc">CNPJ</label>
                <input type="number" id="doc" name="cnpj" required autofocus placeholder="Digite o seu CNPJ">
            </div>

            <div class="campo">
                <label for="login">Login</label>
                <input type="text" id="login" name="login" required placeholder="Digite o seu Login">
            </div>

            <div class="campo">
                <label for="pass">Senha</label>
                <input type="password" id="pass" name="senha" required placeholder="Digite a sua Senha">
            </div>

    <input type="text" name="login" />
    <input type="password" name="senha" />

    <button type="submit">Entrar</button>

</form>