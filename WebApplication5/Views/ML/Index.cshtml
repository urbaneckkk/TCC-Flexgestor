                datasets: [{ label:'Conversao (%)', data:[70.4,70.0,69.6,66.9,66.7,66.2,66.0,65.5,65.5,65.5], backgroundColor:'rgba(79,142,255,0.65)', borderColor:'#4f8eff', borderWidth:1, borderRadius:5 }]
            },
