<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pedidos - FlexGestor</title>
    <link rel="stylesheet" href="/css/homeCSS/home.css">
    <link rel="stylesheet" href="/css/menuCSS/menu.css">
    <link rel="stylesheet" href="/css/pedidoCSS/pedido.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>
<body>
    <div class="container">
        <div id="menu"></div>
        <main>
            <section class="secao-pedidos">

                <div class="cabecalho-tela">
                    <h2>Gerenciamento de Pedidos</h2>
                    <button class="btn-novo-pedido" onclick="abrirModal()">
                        <i class="bi bi-plus-circle-fill"></i> Novo Pedido
                    </button>
                </div>

                <div class="table-container">
                    <div class="area-filtro">
                        <input type="text" id="input-busca-cliente" class="input-filtro"
                               placeholder="Buscar por cliente ou número..." oninput="filtrarCliente()">
                        <div class="filtro-status">
                            <button id="btn-f-todos" class="btn-status-filtro" onclick="setFiltroStatus('todos')">Todos</button>
                            <button id="btn-f-aguardando" class="btn-status-filtro" onclick="setFiltroStatus('aguardando')">Aguardando</button>
                            <button id="btn-f-andamento" class="btn-status-filtro" onclick="setFiltroStatus('andamento')">Em Andamento</button>
                            <button id="btn-f-concluido" class="btn-status-filtro" onclick="setFiltroStatus('concluido')">Concluído</button>
                            <button id="btn-f-cancelado" class="btn-status-filtro" onclick="setFiltroStatus('cancelado')">Cancelado</button>
                        </div>
                    </div>

                    <table class="table-pedidos" id="tabela-pedidos">
                        <thead>
                            <tr>
                                <th>Ações</th>
                                <th>Nº Pedido</th>
                                <th>Status</th>
                                <th>Cliente</th>
                                <th>Data</th>
                                <th>Desconto</th>
                                <th>Total</th>
                                <th>Observação</th>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>

                    <div class="paginacao">
                        <span class="paginacao-info"></span>
                        <div class="paginacao-controles"></div>
                    </div>
                </div>

            </section>
        </main>
    </div>

    <!-- ════════════════════════════════════════
         MODAL: NOVO PEDIDO
    ════════════════════════════════════════ -->
    <div class="modal" id="modal-novo-pedido">
        <div class="modal-content modal-xl">
            <div class="modal-header">
                <h3><i class="bi bi-plus-circle-fill"></i> Novo Pedido</h3>
                <button class="btn-fechar-modal" onclick="fecharModal()">&times;</button>
            </div>

            <!-- ABAS -->
            <div class="modal-tabs">
                <button id="tab-btn-novo-pedido" class="tab-btn ativo" onclick="mudarAba('novo','pedido')">
                    <i class="bi bi-bag-fill"></i> Pedido
                </button>
                <button id="tab-btn-novo-pagamento" class="tab-btn" onclick="mudarAba('novo','pagamento')">
                    <i class="bi bi-credit-card-fill"></i> Pagamentos
                </button>
            </div>

            <div class="modal-body">
                <form id="form-pedido">

                    <!-- PAINEL: PEDIDO -->
                    <div id="tab-novo-pedido" class="tab-painel ativo">
                        <p class="form-secao">Informações do Pedido</p>
                        <div class="form-grid">
                            <div class="form-group">
                                <label>Cliente <span class="obrigatorio">*</span></label>
                                <div class="cliente-selecionado-wrap">
                                    <input type="text" id="novo-cliente-nome" readonly placeholder="Nenhum cliente selecionado">
                                    <input type="hidden" id="novo-cliente-id">
                                    <input type="hidden" id="novo-cliente-endereco">
                                    <button type="button" class="btn-buscar-cliente" onclick="abrirBuscaCliente('novo')">
                                        <i class="bi bi-search"></i> Buscar
                                    </button>
                                </div>
                            </div>
                            <div class="form-group">
                                <label>Desconto Geral (R$)</label>
                                <input type="number" id="novo-desconto" min="0" step="0.01"
                                       placeholder="0,00" oninput="atualizarResumo('novo')">
                            </div>
                            <div class="form-group form-col-2">
                                <label>Observação</label>
                                <textarea id="novo-obs" placeholder="Observações sobre o pedido..."></textarea>
                            </div>
                        </div>

                        <div class="itens-header">
                            <span>Itens do Pedido</span>
                            <button type="button" class="btn-add-item" onclick="adicionarItem('novo')">
                                <i class="bi bi-plus-lg"></i> Adicionar Item
                            </button>
                        </div>

                        <table class="table-itens">
                            <thead>
                                <tr>
                                    <th class="col-produto">Produto</th>
                                    <th class="col-qtde">Qtde</th>
                                    <th class="col-preco">Preço Unit.</th>
                                    <th class="col-desc">Desconto</th>
                                    <th class="col-sub">Subtotal</th>
                                    <th class="col-del"></th>
                                </tr>
                            </thead>
                            <tbody id="novo-itens-body"></tbody>
                        </table>

                        <div class="pedido-resumo">
                            <div class="pedido-resumo-linha">
                                <span>Subtotal dos itens</span>
                                <span id="novo-resumo-subtotal">R$ 0,00</span>
                            </div>
                            <div class="pedido-resumo-linha">
                                <span>Descontos nos itens</span>
                                <span id="novo-resumo-desc-itens">- R$ 0,00</span>
                            </div>
                            <div class="pedido-resumo-linha">
                                <span>Desconto geral</span>
                                <span id="novo-resumo-desc-geral">- R$ 0,00</span>
                            </div>
                            <div class="pedido-resumo-linha total">
                                <span>Total do Pedido</span>
                                <span id="novo-resumo-total">R$ 0,00</span>
                            </div>
                        </div>
                    </div>

                    <!-- PAINEL: PAGAMENTOS -->
                    <div id="tab-novo-pagamento" class="tab-painel">
                        <div class="pag-header">
                            <p class="form-secao" style="margin:0;border:none;padding:0">Pagamentos</p>
                            <button type="button" class="btn-add-item" onclick="adicionarPagamento('novo')">
                                <i class="bi bi-plus-lg"></i> Adicionar Pagamento
                            </button>
                        </div>

                        <div id="novo-pagamentos-lista" class="pagamentos-lista"></div>

                        <div id="novo-pagamentos-resumo" class="pagamentos-resumo"></div>
                    </div>

                    <div class="modal-footer">
                        <button type="button" class="btn-secundario" onclick="fecharModal()">Cancelar</button>
                        <button type="submit" class="btn-primario"><i class="bi bi-check-lg"></i> Salvar Pedido</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- ════════════════════════════════════════
         MODAL: EDIÇÃO
    ════════════════════════════════════════ -->
    <div class="modal" id="modal-edicao">
        <div class="modal-content modal-xl">
            <div class="modal-header">
                <h3><i class="bi bi-pencil-fill"></i> Editar Pedido</h3>
                <button class="btn-fechar-modal" onclick="fecharEdicao()">&times;</button>
            </div>

            <!-- ABAS -->
            <div class="modal-tabs">
                <button id="tab-btn-edit-pedido" class="tab-btn ativo" onclick="mudarAba('edit','pedido')">
                    <i class="bi bi-bag-fill"></i> Pedido
                </button>
                <button id="tab-btn-edit-pagamento" class="tab-btn" onclick="mudarAba('edit','pagamento')">
                    <i class="bi bi-credit-card-fill"></i> Pagamentos
                </button>
            </div>

            <div class="modal-body">
                <form id="form-edicao">

                    <!-- PAINEL: PEDIDO -->
                    <div id="tab-edit-pedido" class="tab-painel ativo">
                        <p class="form-secao">Informações do Pedido</p>
                        <div class="form-grid">
                            <div class="form-group">
                                <label>Número</label>
                                <input type="text" id="edit-numero" readonly>
                            </div>
                            <div class="form-group">
                                <label>Status <span class="obrigatorio">*</span></label>
                                <select id="edit-status" required></select>
                            </div>
                            <div class="form-group">
                                <label>Cliente <span class="obrigatorio">*</span></label>
                                <div class="cliente-selecionado-wrap">
                                    <input type="text" id="edit-cliente-nome" readonly placeholder="Nenhum cliente selecionado">
                                    <input type="hidden" id="edit-cliente-id">
                                    <button type="button" class="btn-buscar-cliente" onclick="abrirBuscaCliente('edit')">
                                        <i class="bi bi-search"></i> Buscar
                                    </button>
                                </div>
                            </div>
                            <div class="form-group">
                                <label>Desconto Geral (R$)</label>
                                <input type="number" id="edit-desconto" min="0" step="0.01"
                                       oninput="atualizarResumo('edit')">
                            </div>
                            <div class="form-group form-col-2">
                                <label>Observação</label>
                                <textarea id="edit-obs"></textarea>
                            </div>
                            <div class="form-group">
                                <label>Frete (R$)</label>
                                <input type="number" id="novo-frete" min="0" step="0.01"
                                       placeholder="0,00" oninput="atualizarResumo('novo')">
                            </div>
                        </div>

                        <div class="itens-header">
                            <span>Itens do Pedido</span>
                            <button type="button" class="btn-add-item" onclick="adicionarItem('edit')">
                                <i class="bi bi-plus-lg"></i> Adicionar Item
                            </button>
                        </div>

                        <table class="table-itens">
                            <thead>
                                <tr>
                                    <th class="col-produto">Produto</th>
                                    <th class="col-qtde">Qtde</th>
                                    <th class="col-preco">Preço Unit.</th>
                                    <th class="col-desc">Desconto</th>
                                    <th class="col-sub">Subtotal</th>
                                    <th class="col-del"></th>
                                </tr>
                            </thead>
                            <tbody id="edit-itens-body"></tbody>
                        </table>

                        <div class="pedido-resumo">
                            <div class="pedido-resumo-linha">
                                <span>Subtotal dos itens</span>
                                <span id="edit-resumo-subtotal">R$ 0,00</span>
                            </div>
                            <div class="pedido-resumo-linha">
                                <span>Descontos nos itens</span>
                                <span id="edit-resumo-desc-itens">- R$ 0,00</span>
                            </div>
                            <div class="pedido-resumo-linha">
                                <span>Desconto geral</span>
                                <span id="edit-resumo-desc-geral">- R$ 0,00</span>
                            </div>
                            <div class="pedido-resumo-linha total">
                                <span>Total do Pedido</span>
                                <span id="edit-resumo-total">R$ 0,00</span>
                            </div>
                        </div>
                    </div>

                    <!-- PAINEL: PAGAMENTOS -->
                    <div id="tab-edit-pagamento" class="tab-painel">
                        <div class="pag-header">
                            <p class="form-secao" style="margin:0;border:none;padding:0">Pagamentos</p>
                            <button type="button" class="btn-add-item" onclick="adicionarPagamento('edit')">
                                <i class="bi bi-plus-lg"></i> Adicionar Pagamento
                            </button>
                        </div>

                        <div id="edit-pagamentos-lista" class="pagamentos-lista"></div>

                        <div id="edit-pagamentos-resumo" class="pagamentos-resumo"></div>
                    </div>

                    <div class="modal-footer">
                        <button type="button" class="btn-secundario" onclick="fecharEdicao()">Cancelar</button>
                        <button type="submit" class="btn-primario"><i class="bi bi-check-lg"></i> Salvar Alterações</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- ════════════════════════════════════════
         MODAL: DETALHES
    ════════════════════════════════════════ -->
    <div class="modal" id="modal-detalhes">
        <div class="modal-content modal-xl">
            <div class="modal-header">
                <h3><i class="bi bi-eye-fill"></i> Detalhes do Pedido</h3>
                <button class="btn-fechar-modal" onclick="fecharDetalhes()">&times;</button>
            </div>
            <div class="modal-body">

                <div class="detalhe-grid">
                    <div class="detalhe-item">
                        <label>Número</label>
                        <span id="det-numero">—</span>
                    </div>
                    <div class="detalhe-item">
                        <label>Status</label>
                        <span id="det-status">—</span>
                    </div>
                    <div class="detalhe-item">
                        <label>Cliente</label>
                        <span id="det-cliente">—</span>
                    </div>
                    <div class="detalhe-item">
                        <label>Data do Pedido</label>
                        <span id="det-data">—</span>
                    </div>
                    <div class="detalhe-item">
                        <label>Desconto</label>
                        <span id="det-desconto">—</span>
                    </div>
                    <div class="detalhe-item">
                        <label>Total</label>
                        <span id="det-total" style="font-size:1.8rem;font-weight:700;color:#1e3c72">—</span>
                    </div>
                    <div class="detalhe-item" style="grid-column:span 2">
                        <label>Observação</label>
                        <span id="det-obs">—</span>
                    </div>
                </div>

                <p class="form-secao">Itens do Pedido</p>
                <table class="table-itens" style="margin-bottom:2rem">
                    <thead>
                        <tr>
                            <th>Produto</th>
                            <th style="text-align:center">Qtde</th>
                            <th>Preço Unit.</th>
                            <th>Desconto</th>
                            <th>Subtotal</th>
                        </tr>
                    </thead>
                    <tbody id="det-itens-body"></tbody>
                </table>

                <p class="form-secao">Pagamentos</p>
                <div id="det-pagamentos"></div>

                <p class="form-secao">Histórico de Status</p>
                <div class="historico-timeline" id="det-historico"></div>

                <div class="modal-footer">
                    <button type="button" class="btn-secundario" onclick="fecharDetalhes()">Fechar</button>
                </div>
            </div>
        </div>
    </div>

    <!-- ════════════════════════════════════════
         MODAL: CONFIRMAÇÃO CANCELAMENTO
    ════════════════════════════════════════ -->
    <div class="modal" id="modal-confirmar">
        <div class="modal-content" style="width:44rem">
            <div class="modal-header">
                <h3><i class="bi bi-exclamation-triangle-fill" style="color:#ef4444"></i> Cancelar Pedido</h3>
                <button class="btn-fechar-modal" onclick="fecharConfirmar()">&times;</button>
            </div>
            <div class="confirm-body">
                <div class="confirm-icone"><i class="bi bi-x-circle-fill"></i></div>
                <p id="confirm-mensagem">Deseja cancelar este pedido?</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn-secundario" onclick="fecharConfirmar()">Não, voltar</button>
                <button type="button" class="btn-perigo" id="confirm-btn-sim">
                    <i class="bi bi-x-circle-fill"></i> Sim, cancelar pedido
                </button>
            </div>
        </div>
    </div>

    <!-- ════════════════════════════════════════
         MODAL: BUSCA DE CLIENTE
    ════════════════════════════════════════ -->
    <div class="modal modal-busca" id="modal-busca-cliente">
        <div class="busca-modal-content">
            <div class="modal-header">
                <h3><i class="bi bi-person-search"></i> Buscar Cliente</h3>
                <button class="btn-fechar-modal" onclick="fecharBuscaCliente()">&times;</button>
            </div>
            <div class="busca-input-wrap">
                <i class="bi bi-search"></i>
                <input type="text" id="input-busca-cliente-modal"
                       placeholder="Buscar por nome ou documento..."
                       oninput="filtrarListaClientes(this.value)">
            </div>
            <div class="busca-lista" id="lista-busca-clientes"></div>
        </div>
    </div>

    <!-- ════════════════════════════════════════
         MODAL: BUSCA DE PRODUTO
    ════════════════════════════════════════ -->
    <div class="modal modal-busca" id="modal-busca-produto">
        <div class="busca-modal-content">
            <div class="modal-header">
                <h3><i class="bi bi-box-seam"></i> Buscar Produto</h3>
                <button class="btn-fechar-modal" onclick="fecharBuscaProduto()">&times;</button>
            </div>
            <div class="busca-input-wrap">
                <i class="bi bi-search"></i>
                <input type="text" id="input-busca-produto-modal"
                       placeholder="Buscar por nome ou código..."
                       oninput="filtrarListaProdutos(this.value)">
            </div>
            <div class="busca-lista" id="lista-busca-produtos"></div>
        </div>
    </div>

    <script src="/js/menuJS/menu.js"></script>
    <script src="/js/shared/flexValidation.js"></script>
    <script src="/js/pedidoJS/pedido.js"></script>
</body>
</html>