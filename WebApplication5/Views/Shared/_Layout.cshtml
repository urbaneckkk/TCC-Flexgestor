@{
    string rota = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    string nomeUsuario = ViewBag.NomeUsuario as string ?? "Usuario";
    string cargo = ViewBag.CargoUsuario as string ?? "Administrador";
    string inicial = nomeUsuario.Length > 0 ? nomeUsuario.Substring(0, 1).ToUpper() : "U";

    string aHome = rota == "Home" ? "nav-item active" : "nav-item";
    string aUsuario = rota == "Usuario" ? "nav-item active" : "nav-item";
    string aCliente = rota == "Cliente" ? "nav-item active" : "nav-item";

    string aEmpresaGroup = rota == "Empresa" ? "nav-group open" : "nav-group";
    string aEmpresaParent = rota == "Empresa" ? "nav-parent active" : "nav-parent";
    string aEmpresaSub = rota == "Empresa" ? "nav-sub-item active" : "nav-sub-item";
}
<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>FlexGestor - @ViewBag.Title</title>
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
    @RenderSection("styles", required: false)
    <style>
        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        :root {
            --bg: #0d0f14;
            --surface: #151820;
            --surface2: #1c2030;
            --accent: #4f8eff;
            --accent2: #a78bfa;
            --text: #e8ecf4;
            --muted: #6b7491;
            --border: #242840;
            --success: #34d399;
            --warning: #fbbf24;
            --danger: #f87171;
        }

        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--bg);
            color: var(--text);
            min-height: 100vh;
            display: flex;
        }

        .sidebar {
            width: 220px;
            min-height: 100vh;
            background: var(--surface);
            border-right: 1px solid var(--border);
            display: flex;
            flex-direction: column;
            position: fixed;
            top: 0;
            left: 0;
            z-index: 100;
        }

        .sidebar-logo {
            padding: 24px 20px 18px;
            border-bottom: 1px solid var(--border);
        }

            .sidebar-logo h1 {
                font-family: 'Syne', sans-serif;
                font-weight: 800;
                font-size: 1.2rem;
                background: linear-gradient(135deg, var(--accent), var(--accent2));
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
            }

            .sidebar-logo span {
                font-size: 0.68rem;
                color: var(--muted);
                letter-spacing: 0.06em;
            }

        .sidebar-nav {
            padding: 12px 10px;
            flex: 1;
            overflow-y: auto;
        }

        .nav-label {
            font-size: 0.6rem;
            color: var(--muted);
            letter-spacing: 0.14em;
            text-transform: uppercase;
            padding: 10px 10px 4px;
            font-weight: 600;
        }

        .nav-item {
            display: flex;
            align-items: center;
            gap: 9px;
            padding: 8px 10px;
            border-radius: 7px;
            color: var(--muted);
            text-decoration: none;
            font-size: 0.83rem;
            transition: all 0.15s;
            margin-bottom: 1px;
        }

            .nav-item:hover {
                background: var(--surface2);
                color: var(--text);
            }

            .nav-item.active {
                background: rgba(79,142,255,0.1);
                color: var(--accent);
            }

            .nav-item .ico {
                width: 15px;
                height: 15px;
                flex-shrink: 0;
            }

            .nav-item .lbl {
                flex: 1;
            }

        .nav-group {
            margin-bottom: 1px;
        }

        .nav-parent {
            display: flex;
            align-items: center;
            gap: 9px;
            padding: 8px 10px;
            border-radius: 7px;
            color: var(--muted);
            font-size: 0.83rem;
            transition: all 0.15s;
            cursor: pointer;
            user-select: none;
        }

            .nav-parent:hover {
                background: var(--surface2);
                color: var(--text);
            }

            .nav-parent.active {
                color: var(--text);
            }

            .nav-parent .ico {
                width: 15px;
                height: 15px;
                flex-shrink: 0;
            }

            .nav-parent .lbl {
                flex: 1;
            }

        .chevron {
            width: 12px;
            height: 12px;
            flex-shrink: 0;
            transition: transform 0.2s;
            opacity: 0.4;
        }

        .nav-group.open .chevron {
            transform: rotate(90deg);
            opacity: 0.8;
        }

        .nav-sub-list {
            overflow: hidden;
            max-height: 0;
            transition: max-height 0.22s ease;
            padding-left: 10px;
        }

        .nav-group.open .nav-sub-list {
            max-height: 300px;
        }

        .nav-sub-item {
            display: flex;
            align-items: center;
            gap: 9px;
            padding: 7px 10px;
            border-radius: 6px;
            color: var(--muted);
            text-decoration: none;
            font-size: 0.79rem;
            transition: all 0.15s;
            margin-bottom: 1px;
            border-left: 2px solid transparent;
        }

            .nav-sub-item:hover {
                color: var(--text);
                border-left-color: var(--muted);
            }

            .nav-sub-item.active {
                color: var(--accent);
                border-left-color: var(--accent);
                background: rgba(79,142,255,0.06);
            }

            .nav-sub-item .ico {
                width: 13px;
                height: 13px;
                flex-shrink: 0;
            }

        .sidebar-footer {
            padding: 12px 10px;
            border-top: 1px solid var(--border);
        }

        .user-card {
            display: flex;
            align-items: center;
            gap: 9px;
            padding: 9px 10px;
            border-radius: 8px;
            background: var(--surface2);
        }

        .user-avatar {
            width: 30px;
            height: 30px;
            border-radius: 7px;
            background: linear-gradient(135deg, var(--accent), var(--accent2));
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Syne', sans-serif;
            font-weight: 700;
            font-size: 0.75rem;
            color: white;
            flex-shrink: 0;
        }

        .user-info {
            flex: 1;
            min-width: 0;
        }

        .user-name {
            font-size: 0.78rem;
            font-weight: 500;
            color: var(--text);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .user-role {
            font-size: 0.65rem;
            color: var(--muted);
        }

        .logout-btn {
            background: none;
            border: none;
            cursor: pointer;
            color: var(--muted);
            padding: 4px;
            display: flex;
            transition: color 0.15s;
            border-radius: 5px;
        }

            .logout-btn:hover {
                color: var(--danger);
            }

            .logout-btn svg {
                width: 13px;
                height: 13px;
            }

        .main {
            margin-left: 220px;
            flex: 1;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        .topbar {
            height: 56px;
            background: var(--surface);
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            padding: 0 28px;
            position: sticky;
            top: 0;
            z-index: 50;
        }

        .topbar-title {
            font-family: 'Syne', sans-serif;
            font-weight: 700;
            font-size: 0.95rem;
            flex: 1;
        }

        .page-content {
            padding: 28px;
            flex: 1;
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        @@keyframes fadeUp {
            from {
                opacity: 0;
                transform: translateY(10px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
    </style>
</head>
<body>

    <aside class="sidebar">
        <div class="sidebar-logo">
            <h1>FlexGestor</h1>
            <span>Painel de Gestao</span>
        </div>
        <nav class="sidebar-nav">

            <div class="nav-label">Principal</div>

            <a href="/Home" class="@aHome">
                <svg class="ico" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
                </svg>
                <span class="lbl">Home</span>
            </a>

            <div class="nav-label" style="margin-top:6px">Cadastros</div>

            <a href="/Usuario" class="@aUsuario">
                <svg class="ico" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                <span class="lbl">Usuarios</span>
            </a>

            <a href="/Cliente" class="@aCliente">
                <svg class="ico" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                </svg>
                <span class="lbl">Clientes</span>
            </a>

            <div class="@aEmpresaGroup" id="grupoEmpresas">
                <div class="@aEmpresaParent" onclick="toggleNav('grupoEmpresas')">
                    <svg class="ico" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
                    </svg>
                    <span class="lbl">Empresas</span>
                    <svg class="chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                    </svg>
                </div>
                <div class="nav-sub-list">
                    <a href="/Empresa" class="@aEmpresaSub">
                        <svg class="ico" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 10h16M4 14h16M4 18h16" />
                        </svg>
                        Listar
                    </a>
                    <a href="/Empresa/Filiais" class="nav-sub-item">
                        <svg class="ico" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                            <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                        </svg>
                        Filiais
                    </a>
                </div>
            </div>

        </nav>
        <div class="sidebar-footer">
            <div class="user-card">
                <div class="user-avatar">@inicial</div>
                <div class="user-info">
                    <div class="user-name">@nomeUsuario</div>
                    <div class="user-role">@cargo</div>
                </div>
                <a href="/Login/Sair" class="logout-btn" title="Sair">
                    <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
                    </svg>
                </a>
            </div>
        </div>
    </aside>

    <div class="main">
        <div class="topbar">
            <div class="topbar-title">@ViewBag.Title</div>
            @RenderSection("topbar", required: false)
        </div>
        <div class="page-content">
            @RenderBody()
        </div>
    </div>

    <script>
        function toggleNav(id) {
            document.getElementById(id).classList.toggle('open');
        }
    </script>
    @RenderSection("scripts", required: false)
</body>
</html>
